# ==============================================================================
# Momentum AI — Environment Configuration Blueprint (.env.example)
# This file documents all required and optional environment variables used for:
# Google Gemini, Supabase, PostgreSQL, Google Calendar, Firebase, Auth, JWT,
# Backend Server, and Frontend client configurations.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. RUNTIME & BACKEND SERVER CONFIGURATIONS
# ------------------------------------------------------------------------------
# NODE_ENV: Set to 'production' in deployed environments or 'development' locally.
NODE_ENV=development

# PORT: The port that the Express backend binds to. Note: In the AI Studio preview
# container environment, the proxy routes exclusively to port 3000.
PORT=3000

# SESSION_SECRET: Encryption key used for securing session cookies and state encryption.
SESSION_SECRET="momentum-secure-session-key-32-chars-long"


# ------------------------------------------------------------------------------
# 2. GOOGLE GEMINI AI CONFIGURATION (CRITICAL)
# ------------------------------------------------------------------------------
# GEMINI_API_KEY: The API key for Google GenAI SDK (gemini-3.5-flash).
# In AI Studio, this key is managed via the Settings -> Secrets menu.
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"


# ------------------------------------------------------------------------------
# 3. GOOGLE WORKSPACE & GOOGLE CALENDAR INTEGRATIONS
# ------------------------------------------------------------------------------
# GOOGLE_CLIENT_ID: OAuth 2.0 Client ID for Google Workspace/Calendar authorization.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# GOOGLE_CLIENT_SECRET: OAuth 2.0 Client Secret corresponding to the Client ID.
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# GOOGLE_REDIRECT_URI: The callback URI where Google OAuth returns auth codes.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/oauth2callback"


# ------------------------------------------------------------------------------
# 4. DATABASE & PERSISTENCE CONFIGURATIONS (POSTGRESQL & SUPABASE)
# ------------------------------------------------------------------------------
# DATABASE_URL: Standard PostgreSQL connection string (Postgres/Cloud SQL/Supabase PG).
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:secure-db-password@localhost:5432/momentum_db"

# PG_CONNECTION_STRING: Alias for DATABASE_URL used by Drizzle ORM / legacy systems.
PG_CONNECTION_STRING="postgresql://postgres:secure-db-password@localhost:5432/momentum_db"

# NEXT_PUBLIC_SUPABASE_URL: The public API URL of your Supabase instance.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: The public anonymous key for Supabase client initialization.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here"

# SUPABASE_SERVICE_ROLE_KEY: The secret high-privilege service-role key for backend bypasses.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here"


# ------------------------------------------------------------------------------
# 5. FIREBASE INTEGRATION CONFIGURATIONS
# ------------------------------------------------------------------------------
# FIREBASE_PROJECT_ID: The unique ID of the target Firebase Firestore project.
FIREBASE_PROJECT_ID="citric-program-499618-p9"

# FIREBASE_API_KEY: Web client API Key corresponding to your Firebase App.
FIREBASE_API_KEY="AIzaSyDDvzf4GWiXYTqZRlFz03697eeZI_YxXj4"

# FIREBASE_AUTH_DOMAIN: Domain prefix used for Firebase Web Authentication handlers.
FIREBASE_AUTH_DOMAIN="citric-program-499618-p9.firebaseapp.com"

# FIREBASE_STORAGE_BUCKET: Storage cloud bucket URL for attachment storage.
FIREBASE_STORAGE_BUCKET="citric-program-499618-p9.firebasestorage.app"

# FIREBASE_MESSAGING_SENDER_ID: Sender identifier for push/cloud messaging notifications.
FIREBASE_MESSAGING_SENDER_ID="895021466726"

# FIREBASE_APP_ID: Unique registration ID of the Firebase web application.
FIREBASE_APP_ID="1:895021466726:web:b6b3e8928a8e339b3399a7"


# ------------------------------------------------------------------------------
# 6. ENHANCED SECURITY & AUTHENTICATION (JWT)
# ------------------------------------------------------------------------------
# JWT_SECRET: Secret phrase used for encrypting, signing, and verifying custom tokens.
JWT_SECRET="momentum-ai-super-secret-jwt-key-256-bit"

# JWT_EXPIRES_IN: The lifespan constraint for issued authentication session tokens.
JWT_EXPIRES_IN="30d"


# ------------------------------------------------------------------------------
# 7. FRONTEND SPECIFIC URL CONFIGURATIONS
# ------------------------------------------------------------------------------
# APP_URL: Base URL of the web applet, used for absolute self-referencing.
APP_URL="http://localhost:3000"

# VITE_APP_URL: Exposes the base URL value to the Vite client-side bundle.
VITE_APP_URL="http://localhost:3000"

# VITE_API_URL: Direct path prefix for the REST API routing (optional, defaults to /api).
VITE_API_URL="http://localhost:3000/api"
